{
  "version": 2,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.2",
      "maxDuration": 30
    }
  },
  "buildCommand": "npm install && npm run build",
  "outputDirectory": "public",
  "routes": [
    { "src": "/(.*\\.php)", "dest": "/api/index.php" },
    { "src": "/", "dest": "/api/index.php" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}
